{
  "name": "react-text-labeler",
  "version": "1.0.0",
  "description": "A reusable labeler component for text and text streams.",
  "keywords": [
    "react",
    "labeler",
    "text",
    "stream",
    "annotate",
    "labels",
    "annotator"
  ],
  "homepage": "https://github.com/omarsourour/react-text-labeler#readme",
  "bugs": {
    "url": "https://github.com/omarsourour/react-text-labeler/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omarsourour/react-text-labeler.git"
  },
  "license": "MIT",
  "author": "Omar Sourour",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite",
    "eslint": "eslint . --ext .ts,.tsx",
    "postinstall": "husky",
    "lint": "eslint",
    "pre-commit": "lint-staged",
    "prettier-lint": "prettier --check .",
    "preview": "vite preview",
    "stylelint": "stylelint \"**/*.{css,scss}\" --allow-empty-input",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "mobx": "^6.13.7",
    "mobx-react": "^9.2.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.31.0",
    "husky": "^9.1.7",
    "jest": "^30.0.4",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-packagejson": "^2.5.18",
    "react-dom": "^19.1.0",
    "stylelint": "^16.21.1",
    "stylelint-config-css-modules": "^4.5.1",
    "stylelint-config-property-sort-order-smacss": "^10.0.0",
    "stylelint-prettier": "^5.0.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0",
    "vite": "^7.0.4"
  },
  "peerDependencies": {
    "react": "^19.1.0"
  }
}
